{
  "name": "time-announcement-qiita",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {},
  "settings": {
    "terminal.integrated.defaultProfile.linux": "zsh"
  },
  "remoteUser": "vscode",
  "postCreateCommand": "python -m pip install --upgrade pip && python -m pip install qiita-sync",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "yzhang.markdown-all-in-one"
      ]
    }
  },
  "runArgs": [
    "--env-file",
    "${localWorkspaceFolder}/.env"
  ]
}
